# Copy this to .env and fill in values. Never commit .env.

# ── LLM — script generation (FREE) ───────────────────────────────────────────

# Gemini 1.5 Flash — Hindi scripts (aistudio.google.com → Get API Key, free)
GOOGLE_API_KEY=

# ── TTS — Hindi voiceover ─────────────────────────────────────────────────────

# Sarvam Bulbul — natural Hindi TTS (sarvam.ai → API → Get Key)
SARVAM_API_KEY=sk_fch5cv5a_IauOTeN2Wz0PG3UIVhYZC0JZ
SARVAM_SPEAKER=anushka    # female: anushka,manisha,priya,neha | male: rahul,rohan,abhilash,karun

# ── THUMBNAILS ────────────────────────────────────────────────────────────────

# DALL-E 3 (platform.openai.com → API Keys) — used for thumbnails only
# Cost: ~$0.08/thumbnail
OPENAI_API_KEY=

# OpenRouter — used for per-segment AI scene images in shorts (scene_image_agent.py),
# model google/gemini-2.5-flash-image. openrouter.ai → Keys.
# Cost: ~$0.0003/image, ~4-6 images/episode → well under $0.01/episode.
OPENROUTER_API_KEY=

# ── FREE APIs ─────────────────────────────────────────────────────────────────

# B-roll footage (pexels.com/api → Your API Key)
PEXELS_API_KEY=

# B-roll footage (pixabay.com/api/docs → API Key)
PIXABAY_API_KEY=

# News aggregation — 100 req/day free (newsapi.org → Get API Key)
NEWS_API_KEY=

# Indian court judgments — free API (indiankanoon.org/api → register)
INDIAN_KANOON_TOKEN=

# General web search — works for ANY case topic, not just crime/India.
# console.cloud.google.com → APIs & Services → Custom Search API → enable +
# create API key, free tier 100 queries/day. CSE ID from
# programmablesearchengine.google.com (create a search engine, "search the
# entire web" mode, copy its Search engine ID).
GOOGLE_SEARCH_API_KEY=
GOOGLE_CSE_ID=

# YouTube upload + analytics — free quota 10K units/day
# (console.cloud.google.com → APIs → YouTube Data API v3 → Credentials)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# ── CLOUD INFRASTRUCTURE (free tiers) ────────────────────────────────────────

# Database: Neon — free 0.5GB PostgreSQL (neon.tech)
# Get: console.neon.tech → New Project → Connection Details → Connection string
DATABASE_URL=postgresql://user:pass@ep-xxx-yyy.us-east-2.aws.neon.tech/indiancrimes?sslmode=require

# Storage: Cloudflare R2 — 10GB free, zero egress fees (dash.cloudflare.com → R2)
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=indiancrimes-videos
CLOUDFLARE_R2_ENDPOINT=https://{ACCOUNT_ID}.r2.cloudflarestorage.com

# ── APP CONFIG ────────────────────────────────────────────────────────────────

ENVIRONMENT=development
LOG_LEVEL=INFO
DATA_DIR=./data

# Dashboard: streamlit run src/dashboard/app.py → http://localhost:8501
# Orchestrator: python main.py
